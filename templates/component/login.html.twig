<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Perline Cookie</title>

    <link rel="stylesheet" href="{{ asset('css/login.css') }}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>

    <a href="{{ path('app_home') }}" class="back-btn">Retour</a>

    <div class="container">
        <div class="form">

            <div class="logo">
                <a href="{{ path('app_home') }}">
                    <img
                        src="{{ asset('asset/perline.png') }}"
                        alt="Logo"
                        style="max-width:150px; height:auto; border-radius:10px;"
                    >
                </a>
            </div>

            <form method="post" action="{{ path('app_login') }}">

                {% if error %}
                    <div class="alert">
                        {% if 'Trop de tentatives' in error.message %}
                            {{ error.message }}
                        {% else %}
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        {% endif %}
                    </div>
                {% endif %}

               

                <!-- EMAIL -->
                <div class="inputBox">
                    <input
                        type="email"
                        name="email"
                        value="{{ last_username }}"
                        placeholder=" "
                        autocomplete="email"
                        required
                    >
                    <span>Email</span>
                </div>

                <!-- PASSWORD -->
                <div class="inputBox" style="position:relative;">
                    <input
                        type="password"
                        name="password"
                        id="password"
                        placeholder=" "
                        autocomplete="current-password"
                        required
                        style="padding-right:45px;"
                    >

                    <span>Mot de passe</span>

                    <i
                        class="fas fa-eye"
                        id="togglePassword"
                        onclick="togglePass()"
                        style="position:absolute; right:15px; top:17px; cursor:pointer; color:#666; font-size:1.1em; z-index:999;"
                    ></i>
                </div>

                <input
                    type="hidden"
                    name="_csrf_token"
                    value="{{ csrf_token('authenticate') }}"
                >

                <button type="submit" class="enter">CONNEXION</button>

                <div class="links">
                    <a href="{{ path('app_forgot_password_request') }}">Mot de passe oublié ?</a>
                    <a href="{{ path('app_register') }}">Créer ton compte </a>
                </div>

            </form>
        </div>
    </div>

    <script src="{{ asset('js/login.js') }}"></script>

</body>
</html>