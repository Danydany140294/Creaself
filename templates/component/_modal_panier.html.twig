{# templates/panier/_modal_panier.html.twig #}

{# ========== STYLES CSS ========== #}
<link rel="stylesheet" href="{{ asset('css/modal_panier.css') }}">

{# Modal Panier #}
<div id="modalPanier" class="cart-overlay" style="display: none;">
    <div class="cart-modal-container glass-premium">
        
        <!-- Section Gauche : Articles -->
        <section class="cart-items-panel">
            <header class="panel-header">
                <div class="title-group">
                    <h2>
                        <i class="fa-solid fa-basket-shopping"></i>
                        Mon <span class="pink-text italic">Panier</span>
                    </h2>
                    <span class="items-count" id="itemsCount">● 0 Articles</span>
                </div>
                <a href="#" class="back-shop" onclick="closeModalPanier(); return false;">
                    ← CONTINUER MES ACHATS
                </a>
            </header>

            <div class="items-scroll-list" id="panierContent">
                <div class="loading-panier">
                    <i class="fas fa-spinner fa-spin"></i>
                    <p>Chargement du panier...</p>
                </div>
            </div>
        </section>

        <!-- Section Droite : Résumé -->
        <aside class="cart-summary-panel">
            <button class="close-modal-btn" onclick="closeModalPanier()">✕</button>
            
            <h3>RÉSUMÉ</h3>
            
            <div class="shipping-card glass" id="shippingProgress" style="display: none;">
                <p>Livraison Gratuite <span class="remaining-cost" id="remainingCost">0,00 € restant</span></p>
                <div class="progress-bar">
                    <div class="progress-fill" id="progressFill" style="width: 0%;"></div>
                </div>
                <span class="reward-tag">LIVRAISON OFFERTE DÈS 50,00 €</span>
            </div>

            <div class="bill-details" id="billDetails">
                <div class="bill-line">
                    <span>Sous-total</span>
                    <span id="subtotalValue">0,00 €</span>
                </div>
                <div class="bill-line">
                    <span>Livraison</span>
                    <span id="shippingValue">4,90 €</span>
                </div>
                <div class="bill-line">
                    <span>TVA estimée</span>
                    <span id="taxValue">0,00 €</span>
                </div>
            </div>

            <div class="total-section">
                <span class="total-label">TOTAL</span>
                <span class="total-value" id="totalValue">0,00 €</span>
            </div>

            <a href="{{ path('app_panier_index') }}" class="checkout-btn-neon">
                VOIR LE PANIER COMPLET
                <span class="arrow">→</span>
            </a>

            <div class="payment-icons">
                <span>💳</span><span>📱</span><span>🅿️</span><span>🔒</span>
            </div>
        </aside>
    </div>
</div>

{# ========== JAVASCRIPT ========== #}
<script>
    window.PANIER_PATHS = {
    uploadsBase: '{{ asset('asset/images/') }}',
    imagesBase: '{{ asset('asset/images/') }}',
    apiBase: '{{ path('app_panier_api') }}'.replace('/api', '')
};
    
    console.log('🔧 Configuration PANIER_PATHS:', window.PANIER_PATHS);
</script>
<script src="{{ asset('js/modal_panier.js') }}"></script>