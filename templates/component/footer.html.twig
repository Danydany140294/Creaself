                </a>
                <a href="https://tiktok.com" target="_blank" rel="noopener" class="social-link" aria-label="TikTok">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.73a4.85 4.85 0 01-1.01-.04z"/>
                    </svg>
                </a>
            </div>
        </div>

        {# ====== NAVIGATION ====== #}
        <div class="footer-col">
            <button class="footer-col-title footer-toggle" aria-expanded="false">
                Navigation
                <span class="footer-chevron material-symbols-outlined">expand_more</span>
            </button>
            <ul class="footer-links">
                
                <li><a href="{{ path('app_produits') }}">Nos Cookies</a></li>
                <li><a href="#">Nos Box</a></li>
                <li><a href="{{ path('app_contact') }}">Contactez-nous</a></li>
                {% if app.user %}
                    <li><a href="{{ path('app_user_dashboard') }}">Mon Compte</a></li>
                {% else %}
                    <li><a href="{{ path('app_login') }}">Se connecter</a></li>
                {% endif %}
            </ul>
        </div>

        {# ====== CONTACT ====== #}
        <div class="footer-col">
            <button class="footer-col-title footer-toggle" aria-expanded="false">
                Nous trouver
                <span class="footer-chevron material-symbols-outlined">expand_more</span>
            </button>
            <ul class="footer-links footer-contact-list">
                <li>
                    <span class="material-symbols-outlined contact-icon">location_on</span>
                    <span>12 Rue du Sucre Holographique<br>34000 Montpellier</span>
                </li>
                <li>
                    <span class="material-symbols-outlined contact-icon">mail</span>
                    <a href="mailto:Perlecook@perline-cookies.com">Perlecook@perline-cookies.com</a>
                </li>
            </ul>
        </div>

        {# ====== LÉGAL ====== #}
        <div class="footer-col">
            <button class="footer-col-title footer-toggle" aria-expanded="false">
                Informations légales
                <span class="footer-chevron material-symbols-outlined">expand_more</span>
            </button>
            <ul class="footer-links">
                <li><a href="{{ path('app_mentions_legales') }}">Mentions légales</a></li>
                <li><a href="{{ path('app_cgv') }}">CGV</a></li>
                <li><a href="{{ path('app_politique_confidentialite') }}">Politique de confidentialité</a></li>
                <li><a href="{{ path('app_gestion_cookies') }}">Gestion des cookies</a></li>
            </ul>
        </div>

    </div>

    <div class="footer-bottom">
    <div class="footer-bottom-inner">
        <p class="footer-copyright">
            © {{ "now"|date("Y") }} <span class="footer-brand-name">Perline Cookies</span> — Tous droits réservés.
        </p>
    </div>
</div>

</footer>
