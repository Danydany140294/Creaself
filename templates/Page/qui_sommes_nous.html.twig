{% extends 'base.html.twig' %}

{% block title %}Qui sommes-nous ?{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/quisommesnous.css') }}">
{% endblock %}

{% block body %}

<main class="about-page">

    {# ========== HERO PLEIN ÉCRAN ========== #}
    <section class="hero-full">
        <div class="hero-bg">
            <img src="{{ asset('asset/images/quisommesnous/1.JPG') }}" alt="Perline" class="hero-bg-img">
            <div class="hero-overlay"></div>
        </div>
        <div class="hero-body fade-in">
            <span class="eyebrow">Cookies d'exception</span>
            <h1><span class="gradient-text">Perline Cook</span></h1>
            <p class="hero-desc">Quand l'élégance du design rencontre la rigueur de l'innovation culinaire.</p>
            <div class="hero-scroll-hint">
                <span></span>
                <p>Découvrir</p>
            </div>
        </div>
    </section>

    {# ========== SECTION CRÉATRICE ========== #}
    <section class="split-section">
        
        <div class="split-content glass" data-aos="fade-left">
            <span class="label">FONDATRICE & DESIGNER CULINAIRE</span>
            <h2>L'Âme de <em>Perline</em></h2>
            <p>Architecte de formation, Perline a troqué ses plans pour des recettes millimétrées. Son parcours est une quête perpétuelle d'équilibre entre esthétique pure et émotion gustative.</p>
            <p>Chaque biscuit est pensé comme une pièce de design unique. Sa philosophie ? Le beau ne doit jamais compromettre le bon, il doit le transcender.</p>
            <div class="signature">FONDATRICE & DESIGNER CULINAIRE</div>
        </div>
    </section>

    {# ========== SECTION CHIFFRES ========== #}
    <section class="stats-band">
        <div class="stat-item">
            <span class="stat-number">12</span>
            <span class="stat-label">Saveurs Signature</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <span class="stat-number">100%</span>
            <span class="stat-label">Artisanal</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <span class="stat-number">24h</span>
            <span class="stat-label">Expédition</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <span class="stat-number">∞</span>
            <span class="stat-label">Passion</span>
        </div>
    </section>

    {# ========== SECTION LABO ========== #}
    <section class="split-section reverse">
        <div class="split-image">
            <div class="image-wrap gold-glow">
                <img src="{{ asset('asset/images/quisommesnous/3.JPG') }}" alt="Le laboratoire">
            </div>
            <div class="floating-label gold">LE LABO</div>
        </div>
        <div class="split-content glass" data-aos="fade-right">
            <span class="label">INNOVATION & RIGUEUR</span>
            <h2>Le Labo <br><span class="gold-text">Futuriste</span></h2>
            <p>Ici, la technologie est au service de l'artisanat. Notre atelier est un sanctuaire de lumière où le tempérage se fait avec une précision millimétrique.</p>
            <p>C'est dans ce laboratoire que naît le futur du cookie.</p>
        </div>
    </section>

    {# ========== SECTION SERVICE ========== #}
    <section class="features-section" data-aos="fade-up">
        <div class="features-header">
            <span class="label">LOGISTIQUE D'EXCELLENCE</span>
            <h2>L'Expérience <span class="pink-text">Service Premium</span></h2>
        </div>
        <div class="features-grid">
            <div class="feature-card glass">
                <div class="feature-icon">✦</div>
                <h3>Qualité Sans Compromis</h3>
                <p>Chaque envoi est vérifié par nos soins avant expédition.</p>
            </div>
            <div class="feature-card glass">
                <div class="feature-icon">✦</div>
                <h3>Écrin de Protection</h3>
                <p>Emballages isothermes et anti-chocs haute technicité.</p>
            </div>
            <div class="feature-card glass">
                <div class="feature-icon">✦</div>
                <h3>Suivi Haute Précision</h3>
                <p>Trajectoire de votre coffret suivie en temps réel.</p>
            </div>
        </div>
        <div class="features-image">
            <div class="image-wrap purple-glow wide">
                <img src="{{ asset('asset/images/quisommesnous/2.JPG') }}" alt="Service Premium">
            </div>
        </div>
    </section>

</main>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = "1";
                    entry.target.style.transform = "translateY(0) scale(1)";
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('[data-aos]').forEach(el => {
            el.style.opacity = "0";
            el.style.transform = "translateY(40px) scale(0.97)";
            el.style.transition = "all 0.9s cubic-bezier(0.2, 1, 0.3, 1)";
            observer.observe(el);
        });

        document.querySelectorAll('.image-wrap').forEach(container => {
            container.addEventListener('mousemove', (e) => {
                const { left, top, width, height } = container.getBoundingClientRect();
                const x = (e.clientX - left - width / 2) / 25;
                const y = (e.clientY - top - height / 2) / 25;
                container.style.transform = `perspective(1000px) rotateX(${-y}deg) rotateY(${x}deg)`;
            });
            container.addEventListener('mouseleave', () => {
                container.style.transform = 'rotateX(0deg) rotateY(0deg)';
            });
        });
    </script>
{% endblock %}
