{% extends 'base.html.twig' %}

{% block title %}
    {% if show_success_modal is defined and show_success_modal %}
        Paiement réussi - CreaSelf
    {% else %}
        Paiement - CreaSelf
    {% endif %}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('css/paiement.css') }}">
{% endblock %}

{% block body %}

{# ========================================
   MODAL DE SUCCÈS
   ======================================== #}
{% if show_success_modal is defined and show_success_modal %}
    <div class="modal-overlay" id="successModal" style="display: flex;">
        <div class="confetti"></div>
        <div class="confetti"></div>
        <div class="confetti"></div>
        <div class="confetti"></div>
        <div class="confetti"></div>
        <div class="confetti"></div>
        <div class="confetti"></div>
        <div class="confetti"></div>
        <div class="confetti"></div>

        <div class="modal-container">
            <div class="success-icon-wrapper">
                <div class="success-icon">
                    <i class="fas fa-check"></i>
                </div>
            </div>
            <div class="modal-content">
                <h2>Merci <span>beaucoup</span> !</h2>
                <div class="order-number">
                    <span class="order-number-label">Votre commande</span>
                    <span class="order-number-value" id="orderNumberDisplay">
                        {{ commande.numero }}
                    </span>
                </div>
                <p class="confirmation-message">
                    <i class="fas fa-circle-check"></i>
                    Votre commande d'un montant de <strong>{{ commande.total|number_format(2, ',', ' ') }} €</strong> a été validée avec succès
                </p>
                {% if commande.email %}
                <div class="email-notice">
                    <p>
                        <i class="fas fa-envelope"></i>
                        Un email de confirmation vous a été envoyé à <strong>{{ commande.email }}</strong>
                    </p>
                </div>
                {% endif %}
                <div class="modal-actions">
                    <a href="{{ path('app_home') }}" class="nc-btn nc-btn-primary">
                        <i class="fas fa-home"></i>
                        Retour à l'accueil
                    </a>
                    <a href="{{ path('app_produits') }}" class="nc-btn nc-btn-secondary">
                        <i class="fas fa-cookie-bite"></i>
                        Continuer mes achats
                    </a>
                </div>
            </div>
        </div>
    </div>

{% else %}

{# ========================================
   PAGE DE PAIEMENT NORMALE
   ======================================== #}

<div class="paiement-experience">
    <div class="paiement-container">

        <header class="paiement-header">
            <h1>Finaliser ma <span class="pink-text italic">Commande</span></h1>
        </header>

        <div class="paiement-layout">

            {# ===== ADRESSE DE LIVRAISON ===== #}
            <div class="paiement-card">
                <div class="paiement-card-header">
                    <span class="material-symbols-outlined">location_on</span>
                    <h5>Adresse de livraison</h5>
                </div>
                <div class="paiement-card-body">
                    {% if adresses is empty %}
                        <div class="paiement-alert">
                            Vous n'avez pas encore d'adresse enregistrée.
                            <a href="{{ path('app_user_dashboard') }}#adresses">Ajouter une adresse</a>
                        </div>
                    {% else %}
                        <div class="adresses-grid" id="adresses-container">
                            {% for adresse in adresses %}
                            <div class="adresse-card {{ adresse.parDefaut ? 'selected' : '' }}"
                                 data-id="{{ adresse.id }}"
                                 onclick="selectAdresse(this, {{ adresse.id }})">
                                <div class="adresse-card-top">
                                    <strong>{{ adresse.nom }}</strong>
                                    {% if adresse.parDefaut %}
                                        <span class="badge-default">Par défaut</span>
                                    {% endif %}
                                </div>
                                <p class="adresse-detail">
                                    {{ adresse.rue }}<br>
                                    {% if adresse.complement %}{{ adresse.complement }}<br>{% endif %}
                                    {{ adresse.codePostal }} {{ adresse.ville }}<br>
                                    {{ adresse.pays }}
                                </p>
                            </div>
                            {% endfor %}
                        </div>
                        <a href="{{ path('app_user_dashboard') }}#adresses" class="btn-add-adresse">
                            + Ajouter une adresse
                        </a>
                    {% endif %}
                </div>
            </div>

            {# ===== RÉCAPITULATIF ===== #}
            <div class="paiement-card">
                <div class="paiement-card-header">
                    <span class="material-symbols-outlined">shopping_cart</span>
                    <h5>Récapitulatif</h5>
                </div>
                <div class="paiement-card-body">
                    <div class="recap-line">
                        <span>Sous-total</span>
                        <span>{{ panier.total|number_format(2, ',', ' ') }} €</span>
                    </div>
                    <div class="recap-line">
                        <span>Frais de livraison</span>
                        <span>{{ frais_livraison == 0 ? 'Offerts 🎉' : frais_livraison|number_format(2, ',', ' ') ~ ' €' }}</span>
                    </div>
                    <div class="recap-line recap-total">
                        <span>Total</span>
                        <span class="total-amount">{{ total_final|number_format(2, ',', ' ') }} €</span>
                    </div>
                </div>
            </div>

            {# ===== BOUTON PAYER ===== #}
            <button id="checkout-btn" class="btn-payer {% if adresses is empty %}btn-payer-disabled{% endif %}"
                    {% if adresses is empty %}disabled{% endif %}>
                💳 Payer {{ total_final|number_format(2, ',', ' ') }} €
                <span class="btn-sparkle">✨</span>
            </button>

            <div id="adresse-warning" class="paiement-warning hidden">
                Veuillez sélectionner une adresse de livraison.
            </div>

        </div>
    </div>
</div>

<style>
    .adresse-card {
        cursor: pointer;
        transition: all 0.2s;
    }
    .adresse-card:hover {
        border-color: #198754 !important;
        background: #f8fff9;
    }
    .adresse-card.selected {
        border-color: #198754 !important;
        background: #f0fff4;
    }
</style>

<script src="https://js.stripe.com/v3/"></script>
<script>
    let selectedAdresseId = null;

    // ✅ Pré-sélectionner l'adresse par défaut
    {% for adresse in adresses %}
        {% if adresse.parDefaut %}
            selectedAdresseId = {{ adresse.id }};
            saveAdresse({{ adresse.id }});
        {% endif %}
    {% endfor %}

    function selectAdresse(el, id) {
        document.querySelectorAll('.adresse-card').forEach(c => c.classList.remove('selected'));
        el.classList.add('selected');
        selectedAdresseId = id;
        saveAdresse(id);
        document.getElementById('adresse-warning').classList.add('d-none');
    }

    function saveAdresse(id) {
        fetch('{{ path('app_paiement_choisir_adresse') }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ adresse_id: id })
        });
    }

    document.getElementById('checkout-btn').addEventListener('click', () => {
        if (!selectedAdresseId) {
            document.getElementById('adresse-warning').classList.remove('d-none');
            return;
        }

        const btn = document.getElementById('checkout-btn');
        btn.disabled = true;
        btn.textContent = '⏳ Redirection en cours...';

        fetch('{{ path('app_paiement_create_session') }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        })
        .then(res => res.json())
        .then(data => {
            if (data.sessionId) {
                const stripe = Stripe('{{ stripe_public_key }}');
                stripe.redirectToCheckout({ sessionId: data.sessionId });
            } else {
                alert(data.error || 'Erreur lors du paiement');
                btn.disabled = false;
                btn.textContent = '💳 Payer {{ total_final|number_format(2, ',', ' ') }} €';
            }
        })
        .catch(() => {
            alert('Erreur réseau');
            btn.disabled = false;
        });
    });
</script>

{% endif %}

{% endblock %}


